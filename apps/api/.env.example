# SellScope API Configuration

# App Settings
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# Database
DATABASE_URL=postgresql+asyncpg://sellscope:sellscope@localhost:5432/sellscope

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Scraping
SCRAPE_DELAY_MIN=1.0
SCRAPE_DELAY_MAX=3.0
SCRAPE_MAX_CONCURRENT=5

# AI/ML (optional - for cloud inference)
# OPENAI_API_KEY=
# GOOGLE_AI_API_KEY=

# Make.com Webhook Secret (for verifying incoming webhooks)
MAKE_WEBHOOK_SECRET=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
